# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# ── Supabase (Vite client-side) ──────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── GitHub OAuth App ─────────────────────────────────────
# GitHub → Settings → Developer settings → OAuth Apps 에서 생성
# Authorization callback URL: https://YOUR_PROJECT.supabase.co/auth/v1/callback
# 프로덕션 배포 시 위 callback URL과 아래 Homepage URL을 실제 도메인으로 변경
VITE_GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── AI ───────────────────────────────────────────────────
XAI_API_KEY=your-xai-api-key
